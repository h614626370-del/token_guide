NODE_ENV=production
GUIDE_API_HOST=127.0.0.1
GUIDE_API_PORT=8787
GUIDE_API_PREFIX=/guide-api
GUIDE_API_PUBLIC_ORIGIN=https://kkflow.org
GUIDE_API_DB_PATH=/opt/kkflow-guide/data/guide-api.sqlite
GUIDE_API_ADMIN_TOKEN=replace-with-a-long-random-token
GUIDE_API_IP_HASH_SALT=replace-with-a-long-random-salt
GUIDE_API_CORS_ORIGINS=https://kkflow.org
GUIDE_API_RATE_WINDOW_MS=600000
GUIDE_API_RATE_MAX=5
GUIDE_API_FEEDBACK_DAILY_LIMIT=5
GUIDE_API_TRUST_PROXY=true
GUIDE_API_LOG_LEVEL=warn
GUIDE_API_SUB2API_BASE_URL=https://kkflow.org
GUIDE_API_SUB2API_ADMIN_API_KEY=replace-with-sub2api-admin-api-key
GUIDE_API_PRICING_PLATFORMS=openai,anthropic,gemini,antigravity,grok
GUIDE_API_PRICING_CACHE_TTL_MS=300000
GUIDE_API_PRICING_FETCH_TIMEOUT_MS=8000
GUIDE_API_USD_TO_CNY=6.8102
