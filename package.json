{
  "name": "sub2api-guide",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "site:dev": "vitepress dev apps/guide-site/docs --host 127.0.0.1",
    "site:build": "vitepress build apps/guide-site/docs",
    "site:preview": "vitepress preview apps/guide-site/docs --host 127.0.0.1",
    "docs:dev": "npm run site:dev",
    "docs:build": "npm run site:build",
    "docs:preview": "npm run site:preview",
    "api:dev": "node --watch apps/guide-api/src/server.js",
    "api:start": "node apps/guide-api/src/server.js",
    "deploy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./deploy.ps1",
    "deploy:guide": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-guide.ps1",
    "release:guide-api": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/publish-guide-api.ps1"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
